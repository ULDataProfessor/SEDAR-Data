# Database: PostgreSQL or SQLite
DATABASE_URL=sqlite:///sedar.db
# DATABASE_URL=postgresql://localhost/sedar

# Path to written authorization document (required for live SEDAR+ access)
SEDAR_AUTHORIZATION_FILE=./docs/authorization.example.txt

# Explicit opt-in for live automation (set to 1 when authorized)
SEDAR_CONFIRM_AUTHORIZED=0

# Conservative delay between browser actions (seconds)
SEDAR_RATE_LIMIT_SECONDS=4

# Local directory for downloaded filings
SEDAR_DOWNLOAD_DIR=./filings

# Run browser headless (set false to solve Radware CAPTCHA manually)
SEDAR_HEADLESS=true

# SEDAR+ base URL
SEDAR_BASE_URL=https://www.sedarplus.ca

# Max documents per download batch (SEDAR+ public limit is 30)
SEDAR_MAX_DOWNLOAD_BATCH=30

# Max profiles per document search (SEDAR+ public limit is 50)
SEDAR_MAX_PROFILES_PER_SEARCH=50
